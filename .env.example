# ── Database ──
DATABASE_URL=postgresql://reporelay:reporelay@localhost:5432/reporelay

# ── Embedding ──
EMBEDDING_PROVIDER=ollama
EMBEDDING_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_BATCH_SIZE=64

# ── MCP Server ──
# HTTP port for the MCP server (proxy connects here)
MCP_SERVER_PORT=3000
# Language filter: comma-separated list of languages to include in MCP results.
# When set, the MCP server only returns results from files in these languages.
# When unset, languages are auto-detected from the working directory's manifest
# files (e.g. package.json → typescript/javascript, Cargo.toml → rust).
# Supported: typescript, javascript, python, go, java, kotlin, rust, c, cpp, markdown
# Example: MCP_LANGUAGES=java,kotlin
# MCP_LANGUAGES=
# Language threshold: minimum percentage (0–100) a language must represent in a
# repo ref's language_stats to be considered a match. Only applies when language
# filtering is active (explicit or auto-detected).
# Set to 0 to disable language-based repo filtering entirely.
# Default: 10
# MCP_LANGUAGE_THRESHOLD=10

# ── Web API ──
WEB_PORT=3001

# ── Git ──
GIT_MIRRORS_DIR=.reporelay/mirrors
GIT_WORKTREES_DIR=.reporelay/worktrees

# ── Git Credentials ──
# Tokens for authenticating with remote git hosts over HTTPS.
# Format: GIT_TOKEN_<NORMALIZED_HOST>=<token>
# Host normalization: replace '.' and '-' with '_', then uppercase.
#   e.g. github.com       → GIT_TOKEN_GITHUB_COM
#        gitlab.com       → GIT_TOKEN_GITLAB_COM
#        bitbucket.org    → GIT_TOKEN_BITBUCKET_ORG
#        git.my-corp.com  → GIT_TOKEN_GIT_MY_CORP_COM
#
# GIT_TOKEN_GITHUB_COM=ghp_xxxxxxxxxxxxxxxxxxxx
# GIT_TOKEN_GITLAB_COM=glpat-xxxxxxxxxxxxxxxxxx
# GIT_TOKEN_BITBUCKET_ORG=ATBBxxxxxxxxxxxxxxxx
#
# Optional: override the username used for HTTPS auth on a specific host.
# Auto-detected defaults: github.com → x-access-token, gitlab.com → oauth2,
# bitbucket.org → x-token-auth, everything else → oauth2.
# Format: GIT_USER_<NORMALIZED_HOST>=<username>
#
# GIT_USER_GITEA_MY_CORP_COM=my-service-account

# ── Logging ──
# Level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info


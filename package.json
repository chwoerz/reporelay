{
  "name": "reporelay",
  "version": "1.0.0",
  "description": "A self-hosted, MCP-native code context engine for private repositories.",
  "type": "module",
  "main": "index.js",
  "bin": {
    "reporelay": "./dist/src/mcp-proxy/main.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "./scripts/dev.sh",
    "dev:worker": "tsx watch --env-file=.env src/worker/index.ts",
    "dev:mcp": "tsx --env-file=.env src/mcp/main.ts",
    "dev:web": "tsx watch --env-file=.env src/web/main.ts",
    "dev:proxy": "tsx --env-file=.env src/mcp-proxy/main.ts",
    "dev:ui": "cd ui && npx ng serve",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "generate:api": "kubb && tsx scripts/generate-paths.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "drizzle-orm": "^0.38.0",
    "exit-hook": "^5.1.0",
    "fastify": "^5.3.0",
    "ignore": "^7.0.5",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-to-string": "^4.0.0",
    "minimatch": "^10.2.4",
    "pg-boss": "^12.14.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.0",
    "semver": "^7.7.4",
    "simple-git": "^3.27.0",
    "tree-sitter": "^0.25.0",
    "tree-sitter-c": "^0.23.0",
    "tree-sitter-cpp": "^0.23.0",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.23.0",
    "tree-sitter-kotlin": "^0.3.8",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-rust": "^0.23.0",
    "tree-sitter-typescript": "^0.23.0",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@kubb/cli": "^4.37.1",
    "@kubb/core": "^4.37.1",
    "@kubb/plugin-oas": "^4.37.1",
    "@kubb/plugin-ts": "^4.37.1",
    "@kubb/plugin-zod": "^4.37.1",
    "@types/mdast": "^4.0.4",
    "@types/semver": "^7.7.1",
    "drizzle-kit": "^0.30.0",
    "mermaid": "^11.14.0",
    "prettier": "^3.8.1",
    "testcontainers": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vitest": "^3.0.0",
    "yaml": "^2.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "tree-sitter",
      "tree-sitter-c",
      "tree-sitter-cpp",
      "tree-sitter-go",
      "tree-sitter-java",
      "tree-sitter-javascript",
      "tree-sitter-kotlin",
      "tree-sitter-python",
      "tree-sitter-rust",
      "tree-sitter-typescript"
    ]
  }
}
